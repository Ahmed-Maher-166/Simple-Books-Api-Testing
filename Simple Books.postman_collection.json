          "mode": "raw",
          "raw": "{\r\n   \"clientName\": \"{{clientName}}\",\r\n   \"clientEmail\": \"{{clientEmail}}\"\r\n}\r\n",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{BaseUrl}}/api-clients",
          "host": [
            "{{BaseUrl}}"
          ],
          "path": [
            "api-clients"
          ]
        }
      },
      "response": []
    },
    {
      "name": "GET Books",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();\r",
              "pm.test(\"Products have required keys\", function () {\r",
              " jsonData.forEach(item => {\r",
              "        pm.expect(item).to.have.all.keys(\"id\", \"name\", \"type\", \"available\");\r",
              "    });\r",
              "});\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{BaseUrl}}/books",
          "host": [
            "{{BaseUrl}}"
          ],
          "path": [
            "books"
          ],
          "query": [
            {
              "key": "type",
              "value": "fiction",
              "type": "text",
              "disabled": true
            },
            {
              "key": "limit",
              "value": "2",
              "type": "text",
              "disabled": true
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "GET Books by Id",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"Response has required keys\", function () {\r",
              "    pm.expect(jsonData).to.have.include.keys(\"id\", \"price\", \"type\", \"available\", \"name\", \"created\");\r",
              "});\r",
              "pm.test(\"Response has required key\", function () {\r",
              "    pm.expect(jsonData.id).to.have.eql(pm.collectionVariables.get(\"Bookid\"));\r",
              "});\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.collectionVariables.set(\"Bookid\",Math.trunc(Math.random()*5)+1);\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{BaseUrl}}/books/:bookId",
          "host": [
            "{{BaseUrl}}"
          ],
          "path": [
            "books",
            ":bookId"
          ],
          "variable": [
            {
              "key": "bookId",
              "value": "{{Bookid}}"
            }
          ]
        }
      },
      "response": []
    },
