    {
      "name": "GET Status",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"Your test name\", function () {\r",
              "    pm.expect(jsonData.status).to.eql(\"OK\");\r",
              "});\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{BaseUrl}}/status",
          "host": [
            "{{BaseUrl}}"
          ],
          "path": [
            "status"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Register",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();\r",
              "pm.collectionVariables.set(\"accessToken\",jsonData.accessToken);\r",
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.collectionVariables.set(\"clientName\", \"Ahmed Maher\" + Math.trunc(Math.random()*10));\r",
              "pm.collectionVariables.set(\"clientEmail\", \"AhmedMaher\" + Math.trunc(Math.random()*10000)+\"@gmail.com\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
